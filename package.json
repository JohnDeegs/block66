{
  "name": "block66-monorepo",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "packages/shared",
    "packages/extension",
    "packages/website"
  ],
  "scripts": {
    "build": "npm run build -w packages/shared && npm run build -w packages/extension && npm run build -w packages/website",
    "build:extension": "npm run build -w packages/extension",
    "build:extension:firefox": "npm run build:firefox -w packages/extension",
    "build:website": "npm run build -w packages/website",
    "dev:website": "npm run dev -w packages/website"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
